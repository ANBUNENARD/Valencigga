{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Luxury bag product",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Category e.g. Handbag, Backpack" },
        "images": { "type": "array", "description": "URLs of product images" },
        "stock": { "type": "number", "description": "Available stock quantity" },
        "material": { "type": "string", "description": "Material used" },
        "featured": { "type": "boolean", "description": "Is this a featured product" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID" },
        "items": { "type": "array", "description": "List of items in the order" },
        "totalAmount": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object", "description": "Customer shipping details" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingAddress", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Global product catalog"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "products/{productId}/reviews": {
      "schema": "Review",
      "description": "Reviews for a specific product"
    }
  }
}
